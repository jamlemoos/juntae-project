APP_PORT=8080

# development | staging | production
# In development, a random JWT_SECRET is auto-generated if JWT_SECRET is unset (tokens won't survive restart).
# In staging/production, JWT_SECRET must be set explicitly.
APP_ENV=development

# Required in staging/production. Generate with: openssl rand -hex 32
JWT_SECRET=change-me-in-production-use-a-random-32-byte-hex-string

# Token lifetime in hours (default: 24)
JWT_TTL_HOURS=24

MAIN_DATABASE_URL=host=localhost user=juntae password=juntae dbname=juntae_main port=15432 sslmode=disable TimeZone=America/Fortaleza

AUDIT_DATABASE_URL=host=localhost user=juntae password=juntae dbname=juntae_audit port=15433 sslmode=disable TimeZone=America/Fortaleza

# Comma-separated list of allowed CORS origins. No wildcards in production.
# Defaults to http://localhost:5173 and http://127.0.0.1:5173 when unset.
# Each origin is normalized: whitespace trimmed, trailing slash removed.
# Render env var: ALLOWED_ORIGINS=https://juntae-project.vercel.app
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
